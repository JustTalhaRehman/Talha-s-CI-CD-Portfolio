# AWS Configuration
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-2

# GitHub Actions OIDC Roles
AWS_OIDC_ROLE=arn:aws:iam::123456789012:role/github-actions-staging-role
AWS_PROD_OIDC_ROLE=arn:aws:iam::123456789012:role/github-actions-production-role

# Slack Configuration
SLACK_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Terraform Backend Configuration
TF_STATE_BUCKET=myapp-terraform-state
TF_STATE_KEY=production/terraform.tfstate
TF_DYNAMODB_TABLE=terraform-locks

# Database Configuration (for local development)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myapp
REDIS_URL=redis://localhost:6379/0
